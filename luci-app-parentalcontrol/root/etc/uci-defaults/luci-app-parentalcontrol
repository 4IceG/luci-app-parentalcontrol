#!/bin/sh

chmod +x /usr/libexec/rpcd/parentalcontrol >/dev/null 2>&1 &
chmod +x /usr/libexec/parentalcontrol.sh >/dev/null 2>&1 &
chmod +x /etc/init.d/parentalcontrol >/dev/null 2>&1 &

# Create default config if it doesn't exist
if [ ! -f /etc/config/parentalcontrol ]; then
	cat > /etc/config/parentalcontrol <<-'EOF'
	config global 'global'
		option enabled '1'
	EOF
fi

# Ensure init script is enabled
/etc/init.d/parentalcontrol enable 2>/dev/null

# Restart rpcd to pick up new plugin
/etc/init.d/rpcd restart

rm -rf /tmp/luci-indexcache >/dev/null 2>&1 &
rm -rf /tmp/luci-modulecache/ >/dev/null 2>&1 &
exit 0
